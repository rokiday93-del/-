page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.btn-primary {
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
  border: none;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.btn-default {
  background-color: white;
  color: #333;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.card {
  background-color: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.text-muted {
  color: #999;
  font-size: 28rpx;
}

.text-primary {
  color: #07c160;
  font-weight: 600;
}

.text-danger {
  color: #fa5151;
  font-weight: 600;
}