<view class="container">
  <view class="card user-card">
    <view class="flex-between">
      <view class="flex-start">
        <block wx:if="{{userInfo.avatarUrl}}">
          <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        </block>
        <block wx:else>
          <view class="avatar avatar-placeholder">?</view>
        </block>
        <view class="user-meta">
          <text class="user-name">{{userInfo.nickName || userInfo.name || '未登录'}}</text>
          <text class="user-sub">{{userInfo.isRider ? '骑手' : '普通用户'}}</text>
        </view>
      </view>
      <button class="btn-default" bindtap="bindWechat">{{userInfo.avatarUrl ? '已绑定' : '绑定微信'}}</button>
    </view>

    <view class="info-row">
      <view class="info-item">
        <text class="info-label">学号</text>
        <text class="info-value">{{userInfo.studentId || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">手机号</text>
        <text class="info-value">{{userInfo.phone || '未填写'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">骑手ID</text>
        <text class="info-value">{{userInfo.riderId || '未设置'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{userInfo.isRider}}" class="card stats-card">
    <text class="card-title">骑手统计</text>
    <view class="stats">
      <view class="stat-item">
        <text class="stat-label">接单数</text>
        <text class="stat-value">{{userInfo.orderCount || 0}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">总收入</text>
        <text class="stat-value">¥{{userInfo.totalIncome || 0}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">可提现</text>
        <text class="stat-value">¥{{userInfo.canWithdraw || 0}}</text>
      </view>
    </view>
    <button class="btn-primary" bindtap="goJoin">编辑信息</button>
  </view>

  <view wx:else class="card">
    <text class="text-muted">您还不是骑手，立即入驻获取接单资格</text>
    <button class="btn-primary" bindtap="goJoin">立即入驻</button>
  </view>
</view>
